rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // All writes and the bulk of reads go through the Admin SDK (server-side),
    // which bypasses these rules. The client SDK only reads the activity feed,
    // so that is the only path we open up here. Everything else stays denied.

    // A caller is a member only while their membership is active — removed
    // members keep a doc (status: "removed") but must lose read access.
    function isMember(familyId) {
      return request.auth != null
        && exists(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid))
        && get(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid)).data.status == 'active';
    }

    match /families/{familyId}/activity/{activityId} {
      allow read: if isMember(familyId);
    }

    // Notifications are per-recipient; a member only reads their own. Writes go
    // through the Admin SDK (cron + mark-as-read server action), so stay denied.
    match /families/{familyId}/notifications/{notificationId} {
      allow read: if isMember(familyId)
        && resource.data.recipientUid == request.auth.uid;
    }
  }
}
