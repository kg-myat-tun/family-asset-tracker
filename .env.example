FIREBASE_SERVICE_ACCOUNT_KEY_PATH=./firebase/serviceAccountKey.json
# Optional. Set only if your Firestore database ID is not "(default)" — e.g.
# Firestore Enterprise edition or any custom-named database.
FIRESTORE_DATABASE_ID=
CRON_SECRET=

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Optional. Must match FIRESTORE_DATABASE_ID — used by the client SDK for the
# real-time activity feed listener.
NEXT_PUBLIC_FIRESTORE_DATABASE_ID=
NEXT_PUBLIC_APP_URL=http://localhost:3000
