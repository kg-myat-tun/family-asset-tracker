{
  "permissions": {
    "allow": [
      "Bash(node_modules/.bin/biome check *)",
      "Bash(node_modules/.bin/tsc *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/secret-guard.sh\"",
            "statusMessage": "Checking for secret files"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/post-edit-check.sh\"",
            "timeout": 60,
            "statusMessage": "Typecheck + lint"
          }
        ]
      }
    ]
  }
}
